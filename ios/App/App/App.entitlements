<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- aps-environment must be 'production' for App Store + TestFlight
	     builds. 'development' routes APNS registrations to the sandbox
	     endpoint (api.sandbox.push.apple.com), but App Store/TestFlight
	     builds are signed with a distribution profile and issue
	     production tokens. The mismatch silently dropped every push to
	     iOS users on build 37. -->
	<key>aps-environment</key>
	<string>production</string>
	<!-- Allows the server to mark pushes as `interruption-level:
	     time-sensitive` so they bypass the user's Focus modes for
	     genuinely-time-relevant alerts (visit reminders, follow
	     requests). Without this entitlement iOS silently downgrades
	     time-sensitive pushes to 'active', which Focus mode can
	     suppress. This is a normal app capability — no special Apple
	     review required, but the entitlement must be declared. -->
	<key>com.apple.developer.usernotifications.time-sensitive</key>
	<true/>
	<key>com.apple.developer.applesignin</key>
	<array>
		<string>Default</string>
	</array>
	<!-- Universal Links: iOS fetches
	     https://www.go-roam.uk/.well-known/apple-app-site-association
	     and, for paths declared there, opens this app instead of Safari
	     when a recipient taps a share link. Falls back to Safari if the
	     app isn't installed. -->
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>applinks:www.go-roam.uk</string>
	</array>
</dict>
</plist>
