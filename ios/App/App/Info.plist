<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CAPACITOR_DEBUG</key>
	<string>$(CAPACITOR_DEBUG)</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
        <string>ROAM</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>ROAM uses your location to suggest nearby places to visit, show distances, and centre your offline pack download. Your location is never shared with other users.</string>
	<!-- Apple's static analyzer flags an "always" location reference in
	     a linked SDK (Capacitor Geolocation / RevenueCat / Social Login)
	     even though ROAM itself only ever calls when-in-use. Providing
	     this purpose string satisfies the requirement; the user will
	     only see the "While Using" prompt because that's what our code
	     requests at runtime. Wording mirrors the foreground key so the
	     two read consistently if Apple ever changes which prompt fires. -->
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>ROAM only uses your location while you're using the app, to suggest nearby places and show distances. We never track you in the background.</string>
	<key>NSCameraUsageDescription</key>
	<string>ROAM uses the camera so you can take and share photos of places you visit.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>ROAM uses your photo library so you can attach photos to place tips and reviews.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>ROAM saves the place posters and adventure cards you generate to your photo library.</string>
	<key>NSUserNotificationsUsageDescription</key>
	<string>ROAM sends notifications when friends save places, when someone follows you, and to remind you about places you planned to visit.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.goroam.app</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>roam</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.goroam.app.googlesignin</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.716567148133-lpqnbc7f8aajjrbkqge1r6n6sfq7b4sv</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
