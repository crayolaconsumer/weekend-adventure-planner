<?xml version="1.0" encoding="utf-8"?>
<!--
  ROAM notification status icon. Android system tint applies a single
  colour to the silhouette; the icon MUST be a flat, opaque-white path
  on transparent background. Anything else (gradients, full-colour PNG,
  bevels) is rendered as a white square by Android 5+. Vector drawable
  preferred over multi-density PNGs because system tinting is more
  predictable on the vector path.

  Compass mark — brand-true at a glance, scales cleanly down to 24dp
  status-bar size.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24"
    android:tint="?android:attr/colorControlNormal">
    <!-- Outer compass ring -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M12,2C6.48,2 2,6.48 2,12s4.48,10 10,10 10,-4.48 10,-10S17.52,2 12,2zM12,20c-4.42,0 -8,-3.58 -8,-8s3.58,-8 8,-8 8,3.58 8,8 -3.58,8 -8,8z"/>
    <!-- N-pointing needle (filled diamond) -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M13.5,12L12,5L10.5,12L12,19z"/>
    <!-- Center pivot -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M13,12a1,1 0,1 1,-2 0a1,1 0,0 1,2 0z"/>
</vector>
